{
  "name": "@maiat/viem-guard",
  "version": "0.2.0",
  "description": "Agentic trust layer for viem — trust scoring, anti-poisoning, TrustGateHook integration, and threat reporting",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "viem",
    "ethereum",
    "base",
    "trust",
    "security",
    "web3",
    "maiat"
  ],
  "author": "JhiNResH",
  "license": "MIT",
  "peerDependencies": {
    "viem": ">=2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "viem": "^2.46.3"
  }
}
